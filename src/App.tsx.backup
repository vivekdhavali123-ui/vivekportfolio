  // ─── RENDER ABOUT & SKILLS ───
  const renderAbout = () => (
    <div className="space-y-12 animate-page-enter">

      {/* Description Summary Card */}
      <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div className="lg:col-span-7 space-y-6">
          <div className="glass-panel p-6 sm:p-8 rounded-3xl border-[#111111]/15 shadow-sm">
            <h3 className="font-display text-2xl font-black text-[var(--text-primary)] mb-4">
              Bridging Data Complexity & Commercial Strategy
            </h3>
            <p className="text-sm sm:text-base text-[var(--text-secondary)] leading-relaxed mb-4">
              I am a results-oriented Data Scientist with over 5 years of experience delivering machine learning models, analytics systems, and database interfaces in large-scale environments. My primary focus lies in the hospitality and e-commerce spaces, where customer loyalty models directly affect bottom-line revenues.
            </p>
            <p className="text-sm text-[var(--text-muted)] leading-relaxed">
              Before my consulting roles, I spent years in technical support, order-management analytics, and supply-chain logistics. That coordination background allows me to communicate easily with both engineering squads and commercial executives, helping groups cut manual reporting hours and ensure analytical systems are robust.
            </p>
          </div>
        </div>

        {/* Strengths card */}
        <div className="lg:col-span-5">
          <div className="glass-panel p-6 sm:p-8 rounded-3xl border-[#111111]/15 shadow-sm relative overflow-hidden">
            <div className="absolute top-0 right-0 p-4 opacity-[0.06]">
              <Award className="w-24 h-24 text-[#111111]" />
            </div>
            <h3 className="font-display text-lg font-bold text-[var(--text-primary)] mb-5 flex items-center gap-2">
              <Sparkles className="w-5 h-5 text-[#111111]" />
              Key Pillars
            </h3>
            <ul className="space-y-3.5">
              {[
                'Cross-functional expertise across hospitality, supply chain, and manufacturing.',
                'Mathematical modeling focusing on unsupervised clustering and sequence deep learning.',
                'Strong data visualization capabilities generating clean CRM/executive reports.',
                'Proven record of delivering projects under strict SOW milestones.'
              ].map((pill, idx) => (
                <li key={idx} className="flex items-start gap-3">
                  <div className="mt-1 flex-shrink-0 w-5 h-5 rounded-full bg-[#111111]/10 border border-[#111111]/20 flex items-center justify-center text-[#111111]">
                    <CheckCircle className="w-3.5 h-3.5" />
                  </div>
                  <span className="text-sm text-[var(--text-secondary)] leading-relaxed">{pill}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>

      {/* Skills — Proficiency Chip Grid */}
      <div>
        <div className="text-center mb-10">
          <h3 className="font-display text-2xl font-black text-[#111111] dark:text-[#FFFFFF] mb-2">
            Technical Competencies
          </h3>
          <p className="text-sm text-[#6B6B6B] max-w-md mx-auto">
            Tools and technologies I use daily — sorted by depth of experience.
          </p>
          {/* Legend */}
          <div className="flex items-center justify-center gap-5 mt-4">
            <span className="flex items-center gap-1.5 text-[11px] font-semibold text-[#111111]"><span className="text-[10px]">★★★</span> Expert</span>
            <span className="flex items-center gap-1.5 text-[11px] font-semibold text-[#3F3F3F]"><span className="text-[10px]">★★</span> Advanced</span>
            <span className="flex items-center gap-1.5 text-[11px] font-semibold text-[#6B6B6B]"><span className="text-[10px]">★</span> Proficient</span>
          </div>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-5">
          {skillsData.map((category, idx) => (
            <div key={idx} className="glass-panel p-6 rounded-3xl border-[#111111]/15 shadow-sm gradient-border">
              <div className="flex items-center gap-3 mb-5">
                <div className="p-2.5 rounded-xl bg-[#111111]/10 border border-[#111111]/15 flex items-center justify-center">
                  {category.icon}
                </div>
                <h4 className="font-display text-base font-bold text-[#111111] dark:text-[#FFFFFF]">
                  {category.category}
                </h4>
              </div>

              <div className="flex flex-wrap gap-2">
                {category.items.map((skill, sIdx) => (
                  <span
                    key={sIdx}
                    className={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs transition-all hover:scale-105 hover:shadow-sm cursor-default ${tierStyle(skill.tier)}`}
                  >
                    <span className="text-[9px] opacity-70 tracking-wider">{tierLabel(skill.tier)}</span>
                    {skill.name}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  );

  // ─── RENDER PROJECTS ───
  const renderProjects = () => (
    <div className="animate-page-enter">

      {/* Category tabs */}
      <div className="flex justify-center mb-10">
        <div className="flex flex-wrap items-center justify-center gap-2 p-1.5 bg-white/30 dark:bg-white/5 rounded-2xl border border-[#111111]/15 shadow-sm">
          {['All', 'Hospitality', 'Manufacturing', 'Supply Chain'].map((tab) => (
            <button
              key={tab}
              onClick={() => setActiveTab(tab)}
              className={`px-5 py-2.5 rounded-xl text-xs sm:text-sm font-semibold tracking-wide transition-all ${activeTab === tab
                ? 'opal-tab shadow-sm'
                : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-white/40'
                }`}
            >
              {tab}
            </button>
          ))}
        </div>
      </div>

      {/* Grid */}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {filteredProjects.map((proj) => (
          <div
            key={proj.id}
            onClick={() => setSelectedProject(proj)}
            className="glass-panel p-6 rounded-3xl border-[#111111]/15 flex flex-col justify-between cursor-pointer group gradient-border hover:border-[#111111]/25 shadow-sm"
          >
            <div>
              <div className="flex items-center justify-between mb-4">
                <span className={`px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider ${catBadgeClass(proj.category)}`}>
                  {proj.category}
                </span>
                <span className="text-[#A8A29E] group-hover:text-[#111111] transition-colors">
                  <ArrowUpRight className="w-4.5 h-4.5" />
                </span>
              </div>

              <h3 className="font-display text-base sm:text-lg font-black text-[var(--text-primary)] mb-1.5 leading-snug group-hover:text-[#111111] transition-colors">
                {proj.title}
              </h3>
              <p className="text-[10px] text-[var(--text-muted)] font-bold tracking-wider uppercase mb-4">{proj.client}</p>

              <p className="text-sm text-[var(--text-secondary)] leading-relaxed">
                {proj.summary}
              </p>
            </div>

            <div className="flex flex-wrap gap-1.5 mt-6 pt-4 border-t border-[#111111]/10">
              {proj.tech.slice(0, 3).map((t, idx) => (
                <span key={idx} className="px-2 py-0.5 rounded-md bg-white/45 dark:bg-white/5 border border-[#111111]/12 text-[10px] text-[var(--text-secondary)]">
                  {t}
                </span>
              ))}
              {proj.tech.length > 3 && (
                <span className="px-2 py-0.5 rounded-md bg-[#111111]/10 border border-[#111111]/20 text-[10px] text-[#111111] font-bold">
                  +{proj.tech.length - 3}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>

    </div>
  );

  // ─── RENDER EXPERIENCE ───
  const renderExperience = () => (
    <div className="relative border-l border-[#111111]/20 max-w-3xl mx-auto pl-6 sm:pl-8 space-y-10 animate-page-enter">

      {experienceData.map((exp) => (
        <div key={exp.id} className="relative group/t">

          {/* timeline indicator dot */}
          <div
            className={`absolute -left-[31px] sm:-left-[39px] top-2.5 w-4 h-4 rounded-full border-2 ${exp.isCurrent
              ? 'bg-[#111111] border-white dark:border-[#111111] animate-pulse shadow-md'
              : 'bg-white dark:bg-[#111111] border-[#111111]/30 group-hover/t:border-[#111111]/70 transition-colors'
              }`}
            style={exp.isCurrent ? { boxShadow: '0 0 10px rgba(224,122,95,0.45)' } : {}}
          ></div>

          {/* Job Card */}
          <div className="glass-panel p-6 rounded-3xl border-[#111111]/15 group-hover/t:border-[#111111]/25 shadow-sm transition-all gradient-border">

            <div className="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
              <div>
                <h3 className="font-display text-lg font-black text-[var(--text-primary)] group-hover/t:text-[#111111] transition-colors leading-tight">
                  {exp.role}
                </h3>
                <p className="text-sm font-semibold text-[var(--text-secondary)] mt-0.5">
                  {exp.company}
                </p>
                {exp.location && (
                  <div className="flex items-center gap-1 mt-1.5 text-[11px] text-[#A8A29E] font-semibold">
                    <MapPin className="w-3.5 h-3.5" />
                    {exp.location}
                  </div>
                )}
              </div>

              <div className="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl bg-[#111111]/8 border border-[#111111]/18 text-xs text-[#111111] font-semibold whitespace-nowrap self-start">
                <Calendar className="w-3.5 h-3.5" />
                {exp.period}
              </div>
            </div>

            <ul className="space-y-2.5">
              {exp.highlights.map((highlight, idx) => (
                <li key={idx} className="flex items-start gap-2.5 text-sm text-[var(--text-secondary)] leading-relaxed">
                  <div className="mt-1.5 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-[#111111]/60"></div>
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>

          </div>

        </div>
      ))}

    </div>
  );

  // ─── RENDER CONTACT ───
  const renderContact = () => (
    <div className="grid grid-cols-1 lg:grid-cols-12 gap-8 max-w-5xl mx-auto animate-page-enter">

      {/* Coordinates */}
      <div className="lg:col-span-5 space-y-4">
        <div className="glass-panel p-6 rounded-3xl border-[#111111]/15 space-y-5 shadow-sm">
          <h3 className="font-display text-xl font-bold text-[var(--text-primary)] mb-2">
            Details
          </h3>

          <a
            href="mailto:Vivekdhavali123@gmail.com"
            className="flex items-center gap-4 p-4 rounded-2xl bg-white/40 dark:bg-white/5 hover:bg-white/80 dark:hover:bg-white/10 border border-[#111111]/12 hover:border-[#111111]/35 transition-all group shadow-xs"
          >
            <div className="p-3 rounded-xl bg-[#111111]/10 text-[#111111] group-hover:scale-105 transition-transform flex items-center justify-center">
              <Mail className="w-5 h-5" />
            </div>
            <div className="overflow-hidden">
              <p className="text-[10px] text-var(--text-dim) font-bold uppercase tracking-wider leading-none">Email Address</p>
              <p className="text-sm font-bold text-[var(--text-primary)] mt-1.5 truncate">Vivekdhavali123@gmail.com</p>
            </div>
          </a>

          <a
            href="tel:+919731297187"
            className="flex items-center gap-4 p-4 rounded-2xl bg-white/40 dark:bg-white/5 hover:bg-white/80 dark:hover:bg-white/10 border border-[#111111]/12 hover:border-[#111111]/35 transition-all group shadow-xs"
          >
            <div className="p-3 rounded-xl bg-amber-100 dark:bg-amber-950/20 text-[#3F3F3F] group-hover:scale-105 transition-transform flex items-center justify-center">
              <Phone className="w-5 h-5" />
            </div>
            <div>
              <p className="text-[10px] text-var(--text-dim) font-bold uppercase tracking-wider leading-none">Phone Number</p>
              <p className="text-sm font-bold text-[var(--text-primary)] mt-1.5">+91 9731297187</p>
            </div>
          </a>

          <div className="flex items-center gap-4 p-4 rounded-2xl bg-white/40 dark:bg-white/5 border border-[#111111]/12 shadow-xs">
            <div className="p-3 rounded-xl bg-emerald-100 dark:bg-emerald-950/20 text-[#3F3F3F] flex items-center justify-center">
              <MapPin className="w-5 h-5" />
            </div>
            <div>
              <p className="text-[10px] text-var(--text-dim) font-bold uppercase tracking-wider leading-none">Location</p>
              <p className="text-sm font-bold text-[var(--text-primary)] mt-1.5">Bengaluru, India</p>
            </div>
          </div>

          <div className="pt-4 border-t border-[#111111]/10">
            <p className="text-[10px] text-var(--text-dim) font-bold uppercase tracking-wider mb-3.5">Professional Networks</p>
            <a
              href="https://linkedin.com/in/vivekdhavali/"
              target="_blank"
              rel="noopener noreferrer"
              className="inline-flex items-center gap-2 px-4.5 py-2.5 rounded-xl border border-[#111111]/20 text-xs font-bold text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:border-[#111111]/45 bg-white/10 dark:bg-white/5 hover:bg-white/40 dark:hover:bg-white/10 transition-all shadow-sm"
            >
              <Linkedin className="w-4 h-4 text-[#111111]" />
              LinkedIn Profile
            </a>
          </div>
        </div>
      </div>

      {/* Form Card */}
      <div className="lg:col-span-7">
        <div className="glass-panel p-6 sm:p-8 rounded-3xl border-[#111111]/15 shadow-sm gradient-border">
          <h3 className="font-display text-xl font-bold text-[var(--text-primary)] mb-6">
            Send a Direct Message
          </h3>

          <form onSubmit={handleFormSubmit} className="space-y-5">
            <div>
              <label htmlFor="name" className="block text-[10px] text-[var(--text-secondary)] font-bold uppercase tracking-wider mb-2">Full Name</label>
              <input
                type="text" id="name" name="name"
                value={formData.name} onChange={handleInputChange}
                className={`w-full px-4 py-3.5 rounded-xl text-sm bg-white/70 dark:bg-white/5 border text-[var(--text-primary)] placeholder-[#A8A29E] focus:outline-none focus:ring-1 transition-all ${formErrors.name
                  ? 'border-red-400 focus:ring-red-400'
                  : 'border-[#111111]/20 focus:border-[#111111] focus:ring-[#111111]/20'
                  }`}
                placeholder="e.g. John Doe"
              />
              {formErrors.name && <p className="text-xs text-red-500 font-semibold mt-1.5">{formErrors.name}</p>}
            </div>

            <div>
              <label htmlFor="email" className="block text-[10px] text-[var(--text-secondary)] font-bold uppercase tracking-wider mb-2">Email Address</label>
              <input
                type="email" id="email" name="email"
                value={formData.email} onChange={handleInputChange}
                className={`w-full px-4 py-3.5 rounded-xl text-sm bg-white/70 dark:bg-white/5 border text-[var(--text-primary)] placeholder-[#A8A29E] focus:outline-none focus:ring-1 transition-all ${formErrors.email
                  ? 'border-red-400 focus:ring-red-400'
                  : 'border-[#111111]/20 focus:border-[#111111] focus:ring-[#111111]/20'
                  }`}
                placeholder="e.g. john@example.com"
              />
              {formErrors.email && <p className="text-xs text-red-500 font-semibold mt-1.5">{formErrors.email}</p>}
            </div>

            <div>
              <label htmlFor="message" className="block text-[10px] text-[var(--text-secondary)] font-bold uppercase tracking-wider mb-2">Your Message</label>
              <textarea
                id="message" name="message" rows={4}
                value={formData.message} onChange={handleInputChange}
                className={`w-full px-4 py-3.5 rounded-xl text-sm bg-white/70 dark:bg-white/5 border text-[var(--text-primary)] placeholder-[#A8A29E] focus:outline-none focus:ring-1 transition-all resize-none ${formErrors.message
                  ? 'border-red-400 focus:ring-red-400'
                  : 'border-[#111111]/20 focus:border-[#111111] focus:ring-[#111111]/20'
                  }`}
                placeholder="What details would you like to discuss?"
              />
              {formErrors.message && <p className="text-xs text-red-500 font-semibold mt-1.5">{formErrors.message}</p>}
            </div>

            <button
              type="submit"
              disabled={formSubmitting}
              className="btn-primary w-full py-4 rounded-xl text-base font-bold flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed shadow-md"
            >
              {formSubmitting ? (
                <>
                  <div className="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>
                  <span>Sending Message...</span>
                </>
              ) : (
                <>
                  <span>Send Message</span>
                  <ChevronRight className="w-4 h-4" />
                </>
              )}
            </button>
          </form>
        </div>
      </div>

    </div>
  );

  // ─── 4. CINEMATIC PRELOADER ───
  if (loading) {
    return (
      <div
        className="fixed inset-0 z-50 flex flex-col items-center justify-center overflow-hidden select-none"
        style={{
          backgroundColor: darkMode ? '#111111' : '#f4efeb',
          opacity: loaderPhase === 4 ? 0 : 1,
          transition: 'opacity 0.5s ease'
        }}
      >
        {/* Ambient glow blobs */}
        <div className="absolute inset-0 pointer-events-none">
          <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full blur-[120px]"
            style={{ background: 'radial-gradient(circle, rgba(224,122,95,0.15) 0%, transparent 65%)' }}></div>
        </div>

        <div className="relative z-10 flex flex-col items-center">

          {/* Monogram initials — appears first */}
          <div
            className="font-display font-black text-[120px] sm:text-[160px] leading-none tracking-tighter select-none"
            style={{
              color: 'transparent',
              WebkitTextStroke: `1.5px ${darkMode ? 'rgba(212,163,115,0.35)' : 'rgba(224,122,95,0.25)'}`,
              opacity: loaderPhase >= 1 ? 1 : 0,
              transform: loaderPhase >= 1 ? 'translateY(0)' : 'translateY(12px)',
              transition: 'opacity 0.6s ease, transform 0.6s ease',
            }}
          >
            VD
          </div>

          {/* Full name — appears second */}
          <div
            className="mt-2 overflow-hidden"
            style={{
              opacity: loaderPhase >= 2 ? 1 : 0,
              transform: loaderPhase >= 2 ? 'translateY(0)' : 'translateY(8px)',
              transition: 'opacity 0.55s ease 0.1s, transform 0.55s ease 0.1s',
            }}
          >
            <p className="font-display font-black text-2xl sm:text-3xl tracking-wide text-center"
              style={{ color: darkMode ? '#FFFFFF' : '#111111' }}>
              Vivekanand Dhavali
            </p>
          </div>

          {/* Divider line sweep */}
          <div className="my-5 overflow-hidden" style={{ width: loaderPhase >= 3 ? '200px' : '0px', transition: 'width 0.6s cubic-bezier(0.16, 1, 0.3, 1)' }}>
            <div className="h-px" style={{ background: 'linear-gradient(90deg, transparent, #111111, transparent)' }}></div>
          </div>

          {/* Tagline — appears last */}
          <div
            style={{
              opacity: loaderPhase >= 3 ? 1 : 0,
              transition: 'opacity 0.5s ease 0.2s',
            }}
          >
            <p className="text-[11px] font-bold tracking-[0.25em] uppercase text-center"
              style={{ color: '#111111' }}>
              Data Scientist · Bengaluru, India
            </p>
          </div>

        </div>
      </div>
    );
  }

  return (
    <div className="relative min-h-screen font-sans bg-transparent text-[var(--text-primary)] selection:bg-[#111111]/25 selection:text-[#111111]">

      {/* Dynamic Background Mesh Glows */}
      <div className="absolute top-0 left-1/3 w-[600px] h-[600px] rounded-full blur-[140px] pointer-events-none -translate-y-1/2 animate-pulse-slow"
        style={{ background: 'radial-gradient(circle, rgba(224,122,95,0.12) 0%, transparent 70%)' }}></div>
      <div className="absolute top-1/2 right-0 w-[500px] h-[500px] rounded-full blur-[130px] pointer-events-none animate-pulse-slow"
        style={{ animationDelay: '-4s', background: 'radial-gradient(circle, rgba(242,204,143,0.10) 0%, transparent 70%)' }}></div>
      <div className="absolute bottom-0 left-0 w-[450px] h-[450px] rounded-full blur-[120px] pointer-events-none animate-pulse-slow"
        style={{ animationDelay: '-8s', background: 'radial-gradient(circle, rgba(129,178,154,0.08) 0%, transparent 70%)' }}></div>

      {/* ─── STICKY GLASS NAVIGATION ─── */}
      <header className="sticky top-0 z-45 w-full border-b border-[#111111]/10"
        style={{ background: darkMode ? 'rgba(12, 10, 8, 0.85)' : 'rgba(244, 239, 235, 0.85)', backdropFilter: 'blur(20px)', WebkitBackdropFilter: 'blur(20px)' }}>
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 sm:h-20 flex items-center justify-between">

          {/* Logo brand button */}
          <button
            onClick={() => navigateToPage('home')}
            className="flex items-center gap-3 group focus:outline-none"
          >
            <div className="relative flex items-center justify-center w-10 h-10 rounded-xl shadow-md group-hover:scale-105 transition-all"
              style={{ background: 'linear-gradient(135deg, #111111, #111111)' }}>
              <Database className="w-5 h-5 text-white" />
              <div className="absolute -inset-0.5 rounded-xl blur-sm opacity-0 group-hover:opacity-40 transition-opacity"
                style={{ background: 'linear-gradient(135deg, #111111, #111111)' }} />
            </div>
            <div className="text-left">
              <p className="font-display font-black text-lg text-[var(--text-primary)] leading-none tracking-tight">V. Dhavali</p>
              <p className="text-[10px] text-[#111111] font-bold tracking-widest uppercase mt-0.5">Data Scientist</p>
            </div>
          </button>

          {/* Desktop tabs menu */}
          <nav className="hidden md:flex items-center gap-1.5 bg-[#FAF7F4]/50 dark:bg-white/5 p-1.5 rounded-full border border-[#111111]/15">
            {['home', 'about', 'projects', 'experience', 'contact'].map((page) => (
              <button
                key={page}
                onClick={() => navigateToPage(page)}
                className={`px-4 py-2 rounded-full text-xs sm:text-sm font-semibold capitalize tracking-wide transition-all focus:outline-none ${currentPage === page
                  ? 'opal-tab shadow-sm'
                  : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-white/45'
                  }`}
              >
                {page === 'about' ? 'About & Skills' : page}
              </button>
            ))}
          </nav>

          {/* Theme switcher + Let's Talk button */}
          <div className="flex items-center gap-3">
            {/* Sun/Moon Toggle */}
            <button
              onClick={() => setDarkMode(!darkMode)}
              className="p-2.5 rounded-xl border border-[#111111]/20 text-[#3F3F3F] hover:text-[#111111] dark:text-[#6B6B6B] dark:hover:text-[#FFFFFF] hover:bg-white/40 dark:hover:bg-white/5 transition-all shadow-sm focus:outline-none"
              aria-label="Toggle dark mode theme"
            >
              {darkMode ? <Sun className="w-4.5 h-4.5 text-[#EBE5DF]" /> : <Moon className="w-4.5 h-4.5 text-[#111111]" />}
            </button>

            <button
              onClick={() => navigateToPage('contact')}
              className="hidden lg:flex items-center gap-2 px-5 py-2 rounded-xl text-sm font-bold border border-[#111111]/35 text-[#111111] hover:bg-[#111111]/10 hover:border-[#111111]/60 transition-all shadow-xs"
            >
              Let's Talk
              <Sparkles className="w-3.5 h-3.5" />
            </button>

            {/* Hamburger menu button */}
            <button
              onClick={() => setMenuOpen(!menuOpen)}
              className="md:hidden p-2 rounded-xl text-[var(--text-secondary)] hover:text-[var(--text-primary)] border border-[#111111]/15 hover:bg-white/40 transition-all focus:outline-none"
              aria-label="Toggle menu"
            >
              <Menu className="w-6 h-6" />
            </button>
          </div>
        </div>

        {/* Mobile dropdown */}
        {menuOpen && (
          <div className="md:hidden absolute w-full left-0 border-t border-[#111111]/10 shadow-xl"
            style={{ background: darkMode ? 'rgba(12,10,8,0.98)' : 'rgba(244, 239, 235, 0.98)', backdropFilter: 'blur(20px)', WebkitBackdropFilter: 'blur(20px)' }}>
            <div className="px-3 pt-2 pb-4 space-y-1">
              {['home', 'about', 'projects', 'experience', 'contact'].map((page) => (
                <button
                  key={page}
                  onClick={() => navigateToPage(page)}
                  className={`w-full text-left block px-4 py-3 rounded-xl text-base font-bold capitalize transition-all focus:outline-none ${currentPage === page
                    ? 'text-[#111111] bg-[#111111]/10 border-l-2 border-[#111111] pl-3'
                    : 'text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-white/40'
                    }`}
                >
                  {page === 'about' ? 'About & Skills' : page}
                </button>
              ))}
              <div className="pt-2 px-1">
                <button
                  onClick={() => navigateToPage('contact')}
                  className="btn-primary w-full flex items-center justify-center gap-2 py-3 rounded-xl text-sm shadow-md"
                >
                  Let's Talk
                </button>
              </div>
            </div>
          </div>
        )}
      </header>

      {/* ─── MAIN CONTENT VIEW (Animated Switcher) ─── */}
      <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-16 min-h-[calc(100vh-140px)]">
        <div className={`transition-all duration-300 ${isTransitioning ? 'animate-page-exit' : 'animate-page-enter'
          }`}>
          {currentPage === 'home' && renderHome()}
          {currentPage === 'about' && renderAbout()}
          {currentPage === 'projects' && renderProjects()}
          {currentPage === 'experience' && renderExperience()}
          {currentPage === 'contact' && renderContact()}
        </div>
      </main>

      {/* ─── CASE STUDY DETAILS OVERLAY MODAL ─── */}
      {selectedProject && (
        <div
          className="fixed inset-0 z-50 flex items-center justify-center p-4"
          style={{ background: 'rgba(26,17,11,0.65)', backdropFilter: 'blur(20px)', WebkitBackdropFilter: 'blur(20px)' }}
          onClick={() => setSelectedProject(null)}
        >
          <div
            className="relative w-full max-w-3xl max-h-[85vh] overflow-y-auto glass-panel border-[#111111]/20 rounded-3xl p-6 sm:p-8 shadow-2xl animate-page-enter"
            onClick={e => e.stopPropagation()}
          >
            {/* Close */}
            <button
              onClick={() => setSelectedProject(null)}
              className="absolute top-4 right-4 p-2 rounded-xl text-[#6B6B6B] hover:text-[var(--text-primary)] border border-[#111111]/15 hover:bg-white/40 transition-all"
              aria-label="Close modal"
            >
              <X className="w-5 h-5" />
            </button>

            <div className="mb-6">
              <span className={`inline-block px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider mb-3 ${catBadgeClass(selectedProject.category)}`}>
                {selectedProject.category}
              </span>
              <h3 className="font-display text-xl sm:text-2xl font-black text-[var(--text-primary)] leading-tight">
                {selectedProject.title}
              </h3>
              <p className="text-xs text-[#111111] font-bold tracking-widest uppercase mt-2">{selectedProject.client}</p>
            </div>

            <div className="space-y-6 border-t border-[#111111]/10 pt-6">
              <div>
                <h4 className="text-xs font-bold text-[var(--text-secondary)] uppercase tracking-widest mb-2.5 flex items-center gap-2">
                  <div className="w-1.5 h-1.5 rounded-full bg-[#111111]" />
                  The Challenge
                </h4>
                <p className="text-sm text-[var(--text-secondary)] leading-relaxed pl-3.5">{selectedProject.problem}</p>
              </div>

              <div>
                <h4 className="text-xs font-bold text-[var(--text-secondary)] uppercase tracking-widest mb-2.5 flex items-center gap-2">
                  <div className="w-1.5 h-1.5 rounded-full bg-[#111111]" />
                  Technical Solution
                </h4>
                <p className="text-sm text-[var(--text-secondary)] leading-relaxed pl-3.5">{selectedProject.solution}</p>
              </div>

              <div>
                <h4 className="text-xs font-bold text-[var(--text-secondary)] uppercase tracking-widest mb-3 flex items-center gap-2">
                  <div className="w-1.5 h-1.5 rounded-full bg-emerald-500" />
                  Measurable Impact
                </h4>
                <ul className="space-y-2.5 pl-3.5">
                  {selectedProject.impact.map((item, idx) => (
                    <li key={idx} className="flex items-start gap-2.5 text-sm text-[var(--text-secondary)]">
                      <CheckCircle className="w-4 h-4 text-emerald-600 dark:text-emerald-400 mt-0.5 flex-shrink-0" />
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div>
                <h4 className="text-xs font-bold text-[var(--text-secondary)] uppercase tracking-widest mb-3">
                  Technologies Deployed
                </h4>
                <div className="flex flex-wrap gap-2">
                  {selectedProject.tech.map((t, idx) => (
                    <span key={idx} className="px-3 py-1 rounded-lg bg-white dark:bg-[#120C08] border border-[#111111]/15 text-xs text-[var(--text-secondary)] font-bold">
                      {t}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <div className="mt-8 pt-5 border-t border-[#111111]/10 flex justify-end">
              <button
                onClick={() => setSelectedProject(null)}
                className="px-6 py-2.5 rounded-xl text-sm font-semibold text-[var(--text-secondary)] hover:text-[var(--text-primary)] border border-[#111111]/15 hover:border-[#111111]/35 hover:bg-white/40 transition-all"
              >
                Close Project Details
              </button>
            </div>
          </div>
        </div>
      )}

      {/* ─── SUCCESS FORM MODAL OVERLAY ─── */}
      {formSubmitted && (
        <div
          className="fixed inset-0 z-50 flex items-center justify-center p-4"
          style={{ background: 'rgba(26,17,11,0.65)', backdropFilter: 'blur(20px)', WebkitBackdropFilter: 'blur(20px)' }}
        >
          <div className="glass-panel border-[#111111]/20 rounded-3xl p-8 max-w-sm w-full text-center shadow-2xl">
            <div className="w-16 h-16 rounded-full border border-emerald-500/30 bg-emerald-500/8 flex items-center justify-center mx-auto mb-5 text-emerald-600 dark:text-emerald-400">
              <CheckCircle className="w-8 h-8" />
            </div>
            <h3 className="font-display text-xl font-bold text-[#111111] dark:text-[#FFFFFF] mb-2">Message Sent!</h3>
            <p className="text-sm text-[var(--text-secondary)] leading-relaxed mb-6">
              Thank you for reaching out. Vivekanand will review your inquiry and get back to you shortly.
            </p>
            <button
              onClick={() => setFormSubmitted(false)}
              className="btn-primary w-full py-3 rounded-xl text-sm font-bold shadow-md animate-pulse"
            >
              Back to Portfolio
            </button>
          </div>
        </div>
      )}

      {/* ─── FOOTER ─── */}
      <footer className="border-t border-[#111111]/10 py-12 text-center"
        style={{ background: darkMode ? 'rgba(12,10,8,0.80)' : 'rgba(255, 255, 255, 0.3)' }}>
        <div className="max-w-7xl mx-auto px-4 space-y-2">
          <p className="text-xs text-[var(--text-muted)] font-bold tracking-widest">
            © {new Date().getFullYear()} Vivekanand Dhavali · All Rights Reserved
          </p>
          <p className="text-[10px] text-var(--text-dim) font-semibold">React · TypeScript · Tailwind CSS v4</p>
        </div>
      </footer>

    </div>
  );
}

export default App;
